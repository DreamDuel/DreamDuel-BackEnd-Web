# Environment Configuration
# Copy this file to .env and fill in your values

# App Settings
ENVIRONMENT=development
DEBUG=True
APP_NAME=DreamDuel
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dreamduel_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary File Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend Email Service
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@dreamduel.com

# OAuth 2.0 (Google)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth 2.0 (Apple)
APPLE_CLIENT_ID=com.dreamduel.app
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# Celery Background Jobs
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Sentry Error Tracking (optional)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://dreamduel.com

# API Configuration
API_V1_PREFIX=/api

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# AI Generation Services
# Generator 1: Image Generation (elige una opción)
AI_IMAGE_PROVIDER=replicate  # replicate, openai, stability, custom
REPLICATE_API_KEY=r8_your_replicate_api_key
OPENAI_API_KEY=sk-your_openai_api_key
STABILITY_API_KEY=sk-your_stability_api_key

# Generator 2: Story/Text Generation (elige una opción)
AI_STORY_PROVIDER=openai  # openai, anthropic, custom
OPENAI_API_KEY=sk-your_openai_api_key  # También se usa para GPT-4
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Custom AI Service URLs (si tienes servicios propios)
CUSTOM_IMAGE_API_URL=http://localhost:5001/generate
CUSTOM_STORY_API_URL=http://localhost:5002/generate
CUSTOM_AI_API_KEY=your_custom_api_key
