# ============================================================
# DreamDuel - Variables de Entorno
# ============================================================
# Copia este archivo a .env y llena con tus valores reales.
# NUNCA subas el archivo .env a GitHub.
# En Render/Railway configura estas variables directamente en el dashboard.

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
APP_NAME=DreamDuel
ENVIRONMENT=production           # development | production
DEBUG=False                      # True solo en local
SECRET_KEY=GENERA_CON_generate_secrets.py
FRONTEND_URL=https://tu-dominio.com
API_V1_PREFIX=/api

# ------------------------------------------------------------
# BASE DE DATOS (Render/Railway lo provee automáticamente)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------
# REDIS (Render/Railway lo provee automáticamente)
# ------------------------------------------------------------
REDIS_URL=redis://host:6379/0

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_SECRET=GENERA_CON_generate_secrets.py
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ------------------------------------------------------------
# PAYPAL
# Para producción: ve a developer.paypal.com → Live → tu App
# ------------------------------------------------------------
PAYPAL_MODE=live                 # sandbox | live
PAYPAL_CLIENT_ID=TU_CLIENT_ID_LIVE
PAYPAL_CLIENT_SECRET=TU_SECRET_LIVE
PAYPAL_WEBHOOK_ID=TU_WEBHOOK_ID

# ------------------------------------------------------------
# CLOUDINARY (almacenamiento de imágenes)
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ------------------------------------------------------------
# RESEND (emails)
# ------------------------------------------------------------
RESEND_API_KEY=re_TU_API_KEY
FROM_EMAIL=noreply@dreamduel.com

# ------------------------------------------------------------
# OAUTH (opcional)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ------------------------------------------------------------
# IA (imagen)
# ------------------------------------------------------------
AI_IMAGE_PROVIDER=replicate      # replicate | openai | stability | custom
REPLICATE_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
CUSTOM_IMAGE_API_URL=
CUSTOM_AI_API_KEY=

# ------------------------------------------------------------
# CORS (separados por coma)
# ------------------------------------------------------------
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=100

# ------------------------------------------------------------
# SENTRY (opcional, para monitoreo de errores)
# ------------------------------------------------------------
SENTRY_DSN=
