# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN - DREAMDUEL
# ============================================
# ⚠️ NUNCA SUBIR ESTE ARCHIVO A GITHUB
# ⚠️ Usar en Railway/Render como variables de entorno

# App Settings
ENVIRONMENT=production
DEBUG=False
APP_NAME=DreamDuel
SECRET_KEY=GENERA_CON_generate_secrets.py
FRONTEND_URL=https://tu-dominio.com

# Database (Railway/Render provee automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Railway/Render provee automáticamente)
REDIS_URL=redis://host:6379/0

# JWT Authentication
JWT_SECRET=GENERA_CON_generate_secrets.py
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# PAYPAL - MODO PRODUCCIÓN
# ============================================
# 1. Ve a https://developer.paypal.com/dashboard
# 2. Cambia de "Sandbox" a "Live" (arriba a la derecha)
# 3. Crea una nueva App
# 4. Copia Client ID y Secret

PAYPAL_MODE=live
PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID_LIVE
PAYPAL_CLIENT_SECRET=TU_PAYPAL_SECRET_LIVE
PAYPAL_WEBHOOK_ID=GENERA_EN_PAYPAL_DASHBOARD
PAYPAL_MONTHLY_PLAN_ID=CREA_CON_create_paypal_plan.py
PAYPAL_YEARLY_PLAN_ID=CREA_CON_create_paypal_plan.py

# ============================================
# CLOUDINARY - PRODUCCIÓN
# ============================================
# Usa las mismas credenciales o crea nuevo proyecto
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ============================================
# RESEND EMAIL - VERIFICAR DOMINIO
# ============================================
# 1. Ve a https://resend.com/domains
# 2. Verifica tu dominio (dreamduel.lat)
# 3. Crea una API Key de producción

RESEND_API_KEY=re_TU_API_KEY_DE_PRODUCCION
FROM_EMAIL=noreply@dreamduel.lat

# ============================================
# GOOGLE OAUTH - PRODUCCIÓN
# ============================================
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Edita tu OAuth 2.0 Client ID
# 3. Authorized JavaScript origins:
#    - https://tu-dominio.com
#    - https://tuapp.up.railway.app
# 4. Authorized redirect URIs:
#    - https://tu-dominio.com/auth/callback
#    - https://tuapp.up.railway.app/auth/callback

GOOGLE_CLIENT_ID=123456789-abcdefghijk.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu_google_secret

# ============================================
# APPLE SIGN IN - PRODUCCIÓN
# ============================================
# 1. Ve a https://developer.apple.com/account/resources/identifiers
# 2. Crea Service ID
# 3. Configura dominios y Return URLs
# 4. Genera Private Key (.p8 file)

APPLE_CLIENT_ID=com.dreamduel.app
APPLE_TEAM_ID=TU_TEAM_ID
APPLE_KEY_ID=TU_KEY_ID
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----"

# ============================================
# CELERY - BACKGROUND JOBS
# ============================================
CELERY_BROKER_URL=redis://host:6379/1
CELERY_RESULT_BACKEND=redis://host:6379/2

# ============================================
# SENTRY - ERROR TRACKING
# ============================================
# Opcional pero MUY recomendado para monitoreo
SENTRY_DSN=https://tu_sentry_dsn@o123456.ingest.sentry.io/123456

# ============================================
# CORS - DOMINIOS PERMITIDOS
# ============================================
# Separa con comas todos tus dominios
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# API Configuration
API_V1_PREFIX=/api

# Rate Limiting (producción: más restrictivo)
RATE_LIMIT_PER_MINUTE=100

# ============================================
# AI SERVICES (FUTURO)
# ============================================
# REPLICATE_API_KEY=r8_your_replicate_api_key
# OPENAI_API_KEY=sk-your_openai_api_key
# STABILITY_API_KEY=sk-your_stability_api_key
